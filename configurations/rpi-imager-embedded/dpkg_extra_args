# Documentation
path-exclude=/usr/share/doc/*
path-include=*/share/doc/*/copyright
path-exclude=/usr/share/man/*
path-exclude=/usr/share/groff/*
path-exclude=/usr/share/info/*
# Lintian
path-exclude=/usr/share/lintian/*
path-exclude=/usr/share/linda/*
# Locales / Translations
path-exclude=/usr/share/locale/*
# Bash completion (no interactive shell on the embedded imager)
path-exclude=/usr/share/bash-completion/*
# Perl libraries are pulled in transitively but not used at runtime
path-exclude=/usr/share/perl/*
path-exclude=/usr/share/perl5/*
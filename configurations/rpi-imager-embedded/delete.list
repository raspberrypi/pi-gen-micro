# Charset conversion tables — the AppImage uses ICU, not glibc gconv
usr/lib/aarch64-linux-gnu/gconv

# PAM — no logins, no auth
usr/lib/aarch64-linux-gnu/security
usr/lib/pam.d
etc/pam.conf
etc/pam.d
etc/security
usr/share/pam
usr/share/pam-configs

# polkit/dbus — no privilege escalation needed
usr/share/polkit-1
usr/share/dbus-1

# Fonts — the AppImage bundles its own (Roboto, DejaVu Sans, FreeSans)
usr/share/fonts/truetype/dejavu/DejaVuSansMono-BoldOblique.ttf
usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf
usr/share/fonts/truetype/dejavu/DejaVuSansMono-Oblique.ttf
usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf
usr/share/fonts/truetype/dejavu/DejaVuSerif-Bold.ttf
usr/share/fonts/truetype/dejavu/DejaVuSerif.ttf

# fontconfig templates — AppImage bundles its own fontconfig
usr/share/fontconfig

# debconf cache — build artefact, not needed at runtime
var/cache/debconf

# perl remnants
usr/share/perl5
usr/share/perl-base

# Shell completions — no interactive shell
usr/share/bash-completion
usr/share/zsh

# util-linux extras and coreutils that the imager never shells out to
usr/bin/chage
usr/bin/chfn
usr/bin/csplit
usr/bin/dir
usr/bin/dmesg
usr/bin/du
usr/bin/expr
usr/bin/factor
usr/bin/gpasswd
usr/bin/install
usr/bin/ipcs
usr/bin/localedef
usr/bin/ls
usr/bin/lsfd
usr/bin/nl
usr/bin/numfmt
usr/bin/od
usr/bin/openssl
usr/bin/pr
usr/bin/ptx
usr/bin/resizepart
usr/bin/setpriv
usr/bin/su
usr/bin/tac
usr/bin/tail
usr/bin/tar
usr/bin/taskset
usr/bin/tee
usr/bin/tr
usr/bin/true
usr/bin/truncate
usr/bin/tsort
usr/bin/uclampset
usr/bin/ulockmgr_server
usr/bin/uname
usr/bin/unexpand
usr/bin/uniq
usr/bin/unlink
usr/bin/unshare
usr/bin/update-alternatives
usr/bin/utmpdump
usr/bin/vdir
usr/bin/wc
usr/bin/wdctl
usr/bin/whereis
usr/bin/who
usr/bin/whoami
usr/bin/yes
usr/bin/zdump
